# AI Pocket - Bridge Server Environment Configuration
# Copy this file to .env and fill in your values

# Required: IP address of your ESP32-C6 display
# Find this on the display boot screen or in Arduino Serial Monitor
ESP32_IP=192.168.1.100

# Optional: ESP32 web server port (default: 80)
ESP32_PORT=80

# Optional: Bridge server port (default: 8765)
BRIDGE_PORT=8765

# Optional: Enable Hermes webhook endpoint
HERMES_WEBHOOK=true

# Optional: Enable Telegram monitoring mode
TELEGRAM_MODE=false

# Telegram Bot Configuration (only needed if TELEGRAM_MODE=true)
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
